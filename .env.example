# ============================================================================
#  YourCustomAgentHarness — environment configuration
#
#  1. Copy this file to ".env"   (the real ".env" is git-ignored)
#  2. Fill in the values for YOUR tenant
#  3. Run the harness — every app loads .env automatically at startup
#
#  Notes:
#   * EVERYTHING here is OPTIONAL. With an empty/absent .env the harness runs in
#     DRY mode: it builds, the UI works, and content protection uses the local
#     regex SIT classifier. Fill values in to go LIVE against your tenant.
#   * Real shell / CI environment variables always OVERRIDE these file values.
#   * Never commit secrets. .env is git-ignored for exactly this reason.
# ============================================================================

# ── Tenant / subscription (UI status bar + portal deep-links) ────────────────
TENANT_ID=                 # your Microsoft Entra tenant id (GUID)
TENANT_DOMAIN=             # e.g. contoso.onmicrosoft.com
TENANT_DISPLAY_NAME=       # friendly name shown in the harness UI
ADMIN_UPN=                 # operator / blueprint-owner UPN, e.g. admin@contoso.com
SUBSCRIPTION_ID=           # Azure subscription id (Foundry portal deep-link)

# ── Microsoft Foundry / Azure AI Services (the model backend) ────────────────
FOUNDRY_ACCOUNT=           # Foundry / AI Services account name
FOUNDRY_RESOURCE_GROUP=    # its resource group
FOUNDRY_REGION=            # e.g. eastus2
FOUNDRY_ENDPOINT=          # https://<account>.cognitiveservices.azure.com/
# Model auth: leave AZURE_OPENAI_API_KEY empty to use Entra auth (az login /
# managed identity). Set it to use an API key instead.
AZURE_OPENAI_API_KEY=

# ── Agent Entra app ids (filled after workshop/scripts/provision-agents.ps1) ──
# Each agent's app id doubles as its Purview DLP "location". Per-agent on purpose.
HUB_APP_ID=                # AgenticBank Hub SPA app id (the /hub sign-in app)
FORGEDAGENTONE_APP_ID=     # ForgedAgentOne agent / blueprint app id
FORGEDSCHOLARTWO_APP_ID=   # ForgedScholarTwo agent / blueprint app id

# ── Microsoft Purview content protection ─────────────────────────────────────
Purview__Mode=Auto                 # Auto (Graph first, regex fallback) | Real | Fallback
Purview__DefaultUserObjectId=      # a licensed user OID for Graph attribution
# For LIVE Purview enforcement, let an agent call Graph as its OWN identity
# (it inherits Content.Process.* from the blueprint). NEVER commit a real secret —
# prefer setting Purview__ClientSecret as a real shell env var or in a key vault.
Purview__ClientId=
Purview__ClientSecret=

# ── Web UI (Next.js) ─────────────────────────────────────────────────────────
# Next.js reads NEXT_PUBLIC_* at BUILD time from apps/harness.web/.env.local
# (its own folder), so put these there (copy the values below). They are public
# by design (shipped to the browser) — only non-secret ids belong here.
#   NEXT_PUBLIC_AZURE_TENANT_ID=<your tenant id>
#   NEXT_PUBLIC_AZURE_HUB_CLIENT_ID=<the AgenticBank Hub SPA app id>
#   NEXT_PUBLIC_HUB_REDIRECT_URI=http://localhost:4001/hub
#   NEXT_PUBLIC_HUB_DEFAULT_USER=admin@example.org
